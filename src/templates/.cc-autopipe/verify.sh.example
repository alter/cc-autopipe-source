#!/bin/bash
# verify.sh — emits one JSON line on stdout per SPEC.md §7.7.
# Required keys: passed (bool), score (0..1), prd_complete (bool), details (object).
# Engine times out after 60s.
#
# Replace the project-specific check block (see PROJECT CHECKS below) with the
# real checks for your project (pytest, npm test, docker compose ps,
# integration script, etc). The PRD-completeness block at the bottom should
# work as-is — it counts unchecked items in prd.md.

set -u  # NOT -e: we want to capture failures, not abort on them.

# ---------------------------------------------------------------------------
# PROJECT CHECKS — replace this block with your project's actual gates.
# Each failed check should set ALL_PASS=0. Aim for SCORE to track "fraction
# of checks passing" so the orchestrator's threshold (default 0.85) means
# something concrete.
#
# Defaults below are intentionally fail-closed (passed=false, score=0.0):
# the stub must NOT trick the orchestrator into thinking checks pass when
# none are defined. Set ALL_PASS=1 / SCORE=1.0 only after wiring real
# checks above.
# ---------------------------------------------------------------------------

ALL_PASS=0
SCORE=0.0

# Examples (uncomment and adapt):
#   pytest --tb=line -q                              || ALL_PASS=0
#   npm --prefix frontend run build                  || ALL_PASS=0
#   docker compose -f compose.yml config >/dev/null  || ALL_PASS=0

# ---------------------------------------------------------------------------
# PRD-completeness block.
# Counts unchecked `- [ ]` lines in prd.md. Safe against grep-found-nothing
# (grep exits 1, which would clobber UNCHECKED via `|| echo 0` writing two
# lines — see SPEC-v1.md §1.2). Use `|| true` then default-empty to 0.
# ---------------------------------------------------------------------------

PRD="$(dirname "$0")/../prd.md"
if [ -f "$PRD" ]; then
    UNCHECKED=$(grep -c '^- \[ \]' "$PRD" 2>/dev/null || true)
    UNCHECKED=${UNCHECKED:-0}
    if [ "$UNCHECKED" -eq 0 ]; then
        PRD_COMPLETE="true"
    else
        PRD_COMPLETE="false"
    fi
else
    UNCHECKED=0
    PRD_COMPLETE="false"
fi

cat <<JSON
{
  "passed": $( [ "$ALL_PASS" -eq 1 ] && echo true || echo false ),
  "score": $SCORE,
  "prd_complete": $PRD_COMPLETE,
  "details": {
    "unchecked_prd_items": $UNCHECKED,
    "note": "stub verify.sh — replace PROJECT CHECKS block before running cc-autopipe start"
  }
}
JSON
